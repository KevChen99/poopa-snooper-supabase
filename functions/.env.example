# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

GEMINI_API_KEY=your-gemini-api-key-here

# Shared secret for LMS → analyze-violation calls (machine-to-machine auth).
# If set, upload.py must send this as: Authorization: Bearer <secret>
# Leave blank in local dev; set to a strong random value in production.
EDGE_FUNCTION_SECRET=
